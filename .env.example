# Scrumball Skills Environment Example
# Copy values to your shell or to a local .env loader.

# Required: your API gateway base URL (openapi.json has no servers field)
SCRUMBALL_BASE_URL=https://api.your-domain.com

# Required: unified API key
SCRUMBALL_API_KEY=replace_with_your_api_key

# Optional: set only if your gateway expects "Bearer <token>"
SCRUMBALL_AUTH_PREFIX=

# Optional: request timeout (seconds)
SCRUMBALL_TIMEOUT_SECONDS=30
